// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MEMBER
  VIEWER
}

enum QRStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum QRType {
  URL
  TEXT
  EMAIL
  PHONE
  SMS
  WIFI
  FILE
  VCARD

  WHATSAPP
  GOOGLE_REVIEW

  INSTAGRAM
  FACEBOOK
  LINKEDIN
  X
  YOUTUBE
  TIKTOK

  SOCIAL
}

model User {
  id               Int               @id @default(autoincrement())
  name             String
  email            String            @unique
  password         String
  createdQRCodes   QR[]              @relation("CreatedQRCodes")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  workspaces       Workspace[]
  workspaceMembers WorkspaceMember[]
  qrs              QR[]
  files            File[]
}

model Workspace {
  id          Int               @id @default(autoincrement())
  name        String
  slug        String            @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
  members     WorkspaceMember[]
  folders     Folder[]
  qrs         QR[]
  createdById Int
  createdBy   User              @relation(fields: [createdById], references: [id])
  campaigns   Campaign[]
  files       File[]
}

model WorkspaceMember {
  id Int @id @default(autoincrement())

  workspaceId Int
  userId      Int
  role        Role

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
}

model Folder {
  id   Int    @id @default(autoincrement())
  name String

  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  qrs QR[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, name])
}

model Campaign {
  id Int @id @default(autoincrement())

  name        String
  description String?

  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  qrs QR[]

  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

model QR {
  id          Int      @id @default(autoincrement())
  token       String   @unique
  name        String
  type        QRType   @default(URL)
  content     Json     @default("{}")
  status      QRStatus @default(ACTIVE)
  scanCount   Int      @default(0)
  scanLimit   Int?
  workspaceId Int

  expiresAt   DateTime?
  activeFrom  DateTime?
  activeUntil DateTime?
  password    String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scans     QRScan[]

  createdById Int
  createdBy   User @relation("CreatedQRCodes", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  user   User? @relation(fields: [userId], references: [id])
  userId Int?

  folder   Folder? @relation(fields: [folderId], references: [id])
  folderId Int?

  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  campaignId Int?

  qrdesign QRDesign?

  @@unique([folderId, name])
  @@index([campaignId])
  @@index([workspaceId, folderId])
  @@index([workspaceId])
  @@index([token])
  @@index([status])
}

model QRScan {
  id Int @id @default(autoincrement())

  qrId      Int
  qr        QR       @relation(fields: [qrId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  country   String?
  city      String?
  referer   String?
  device    String?
  browser   String?
  os        String?
  language  String?
  visitorId String?
  scannedAt DateTime @default(now())

  @@index([qrId, scannedAt])
  @@index([country])
  @@index([city])
  @@index([qrId])
  @@index([scannedAt])
}

model File {
  id Int @id @default(autoincrement())

  fileName     String
  originalName String

  mimeType String
  size     Int

  storageKey String
  url        String

  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  uploadedById Int
  uploadedBy   User @relation(fields: [uploadedById], references: [id])

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([workspaceId])
  @@index([uploadedById])
}

model QRDesign {
  id Int @id @default(autoincrement())

  qrId Int @unique

  foregroundColor String?
  backgroundColor String?

  logoFileId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qr QR @relation(fields: [qrId], references: [id], onDelete: Cascade)
}
