// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema


generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  ADMIN
  USER
}

enum QRStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum QRType {
  URL
  TEXT
  EMAIL
  PHONE
  SMS
  WIFI
  FILE
  VCARD
  WHATSAPP
  GOOGLE_REVIEW
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  X
  YOUTUBE
  TIKTOK
  SOCIAL
}

enum PlanInterval {
  DAYS
  MONTHS
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ==========================================
// USER & CORE MODELS
// ==========================================

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  qrs           QR[]
  folders       Folder[]
  campaigns     Campaign[]
  files         File[]
  subscriptions Subscription[]
  payments      Payment[]
}

model Folder {
  id     Int    @id @default(autoincrement())
  name   String
  userId Int
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  qrs QR[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model Campaign {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  qrs QR[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model QR {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  name      String
  type      QRType   @default(URL)
  content   Json     @default("{}")
  status    QRStatus @default(ACTIVE)
  scanCount Int      @default(0)
  scanLimit Int?

  expiresAt   DateTime?
  activeFrom  DateTime?
  activeUntil DateTime?
  password    String?

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  folderId Int?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  campaignId Int?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  scans    QRScan[]
  qrdesign QRDesign?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, folderId, name])
  @@index([userId])
  @@index([token])
  @@index([status])
}

model QRScan {
  id Int @id @default(autoincrement())

  qrId      Int
  qr        QR      @relation(fields: [qrId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  country   String?
  city      String?
  referer   String?
  device    String?
  browser   String?
  os        String?
  language  String?
  visitorId String?
  scannedAt DateTime @default(now())

  @@index([qrId, scannedAt])
  @@index([country])
  @@index([city])
  @@index([qrId])
  @@index([scannedAt])
}

model File {
  id Int @id @default(autoincrement())

  fileName     String
  originalName String
  mimeType     String
  size         Int
  storageKey   String
  url          String

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([userId])
}

model QRDesign {
  id Int @id @default(autoincrement())

  qrId Int @unique
  qr   QR  @relation(fields: [qrId], references: [id], onDelete: Cascade)

  foregroundColor String?
  backgroundColor String?
  logoFileId      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// SUBSCRIPTION & BILLING MODELS
// ==========================================

model SubscriptionPlan {
  id          Int     @id @default(autoincrement())
  name        String  // e.g. "Free Trial", "Monthly Pro", "Yearly Enterprise"
  description String?
  isFree      Boolean @default(false)
  isActive    Boolean @default(true)

  // Pricing & Duration Management
  price             Decimal      @default(0.00) @db.Decimal(10, 2)
  currency          String       @default("USD")
  intervalType      PlanInterval @default(MONTHS) // DAYS or MONTHS
  intervalValue     Int          @default(1)      // e.g., 14 Days, 1 Month, 3 Months, 12 Months

  // --- Numeric & Resource Limits ---
  // Note: Standard convention is null = UNLIMITED
  maxQRCodes        Int?    // Total QR codes user can create
  maxTotalScans     Int?    // Total scans pooled across all QRs
  maxScansPerQR     Int?    // Cap on scans for a single QR code
  maxFolders        Int?    // Maximum folders allowed
  maxQRsPerFolder   Int?    // Maximum QRs allowed per folder
  maxFileUploads    Int?    // Max files user can upload
  maxFileSizeMb     Int?    // Single file upload size limit (in MB)
  maxCampaigns      Int?    // Maximum campaigns allowed

  // --- Feature & Access Flags ---
  allowedQRTypes    Json    @default("[]") // Array of allowed QRType strings, e.g., ["URL", "VCARD"]
  analyticsHistoryDays Int? // Limit analytics access to past N days (null = lifetime)
  allowCustomDesign Boolean @default(true) // Ability to change colors/logo
  allowPasswordProtection Boolean @default(false)
  allowExpiryDate   Boolean @default(false)

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId Int
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  status SubscriptionStatus @default(TRIALING)

  startDate DateTime  @default(now())
  endDate   DateTime? // Calculated based on intervalType + intervalValue
  canceledAt DateTime?

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

model Payment {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  subscriptionId Int?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  amount   Decimal       @db.Decimal(10, 2)
  currency String        @default("USD")
  status   PaymentStatus @default(PENDING)

  provider      String? // e.g. "STRIPE", "RAZORPAY", "PAYPAL"
  transactionId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([subscriptionId])
}