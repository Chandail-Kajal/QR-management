{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],
    "paths": {
      "@": ["./src"],
      "@/*": ["./src/*"],
    }
  },
  "include": ["src/**/*",
    "src/types/**/*",],
  "exclude": ["node_modules", "dist"]
}
